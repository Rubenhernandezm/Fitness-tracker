<Window x:Class="EjercicioFísico.VentanaEjercicioNuevo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EjercicioFísico"
        mc:Ignorable="d"
        Title="VentanaEjercicioNuevo" Height="250" Width="600" Icon="/Recursos/NuevoEjercicio.png">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <TextBlock Text="Nombre:" Grid.Row="0" VerticalAlignment="Center"/>
        <TextBox x:Name="txtNombre" Grid.Row="0" Margin="105,0,250,3"/>

        <TextBlock Text="Descripción:" Grid.Row="1" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDescripcion" Grid.Row="1" Margin="105,0,10,3"/>

        <TextBlock Text="Grupos Musculares:" Grid.Row="2" VerticalAlignment="Center"/>
        <TextBox x:Name="txtGruposMusculares" Grid.Row="2" Margin="105,0,250,3"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Guardar" Width="80" Margin="10,0,0,0" Click="guardar_click"/>
            <Button Content="Cancelar" Width="75" Margin="10,0,0,0" Click="guardar_click"/>
        </StackPanel>

    </Grid>
</Window>
